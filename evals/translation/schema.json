{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://babulfish.dev/evals/translation/schema.json",
  "title": "babulfish translation eval case",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "split",
    "category",
    "sourceLanguage",
    "targetLanguage",
    "contentType",
    "source",
    "references",
    "checks"
  ],
  "properties": {
    "split": {
      "type": "string",
      "enum": ["dev", "holdout", "holdout-clean", "calibration-public"],
      "description": "Legacy flat cases may use holdout. New grouped clean holdout cases should use holdout-clean."
    },
    "category": {
      "type": "string",
      "enum": [
        "plain",
        "ui-label",
        "idiom",
        "technical-docs",
        "punctuation",
        "rtl",
        "named-entity",
        "source-copy-trap",
        "output-only",
        "preservation",
        "markdown",
        "dom",
        "dom-structure",
        "dom-rich-text",
        "dom-attrs",
        "dom-linked",
        "dom-rtl",
        "dom-restore",
        "calibration-public"
      ]
    },
    "sourceLanguage": { "$ref": "#/$defs/language" },
    "targetLanguage": { "$ref": "#/$defs/language" },
    "contentType": {
      "type": "string",
      "enum": ["text", "markdown", "dom"]
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "text": { "type": "string" },
        "html": { "type": "string" }
      }
    },
    "references": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/reference" }
    },
    "checks": { "$ref": "#/$defs/checks" },
    "runner": {
      "$ref": "#/$defs/runner",
      "description": "Optional per-case runner configuration. Used by DOM evals that need richer translator behavior than the default runner config."
    },
    "provenance": {
      "$ref": "#/$defs/provenance",
      "description": "Required for grouped cases. Legacy flat files are temporarily grandfathered during migration."
    }
  },
  "allOf": [
    {
      "if": {
        "properties": { "contentType": { "const": "dom" } },
        "required": ["contentType"]
      },
      "then": {
        "properties": {
          "source": { "required": ["html"] },
          "references": {
            "items": { "required": ["html"] }
          }
        }
      },
      "else": {
        "properties": {
          "source": { "required": ["text"] },
          "references": {
            "items": { "required": ["text"] }
          }
        }
      }
    },
    {
      "if": {
        "properties": { "split": { "const": "holdout-clean" } },
        "required": ["split"]
      },
      "then": {
        "required": ["provenance"],
        "properties": {
          "provenance": {
            "properties": {
              "sourceClass": {
                "enum": [
                  "first_party_authored",
                  "product_derived_rewrite",
                  "synthetic_template"
                ]
              },
              "publicExposure": { "const": "private" },
              "reviewStatus": { "const": "holdout_approved" }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": { "split": { "const": "calibration-public" } },
        "required": ["split"]
      },
      "then": {
        "required": ["provenance"],
        "properties": {
          "provenance": {
            "properties": {
              "sourceClass": {
                "enum": ["public_benchmark", "public_web"]
              },
              "publicExposure": {
                "enum": ["public", "mixed"]
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "provenance": {
            "properties": {
              "sourceClass": {
                "enum": ["public_benchmark", "public_web"]
              }
            },
            "required": ["sourceClass"]
          }
        },
        "required": ["provenance"]
      },
      "then": {
        "properties": {
          "split": { "const": "calibration-public" }
        }
      }
    },
    {
      "if": {
        "properties": {
          "provenance": {
            "properties": {
              "sourceClass": {
                "enum": ["synthetic_template", "product_derived_rewrite"]
              }
            },
            "required": ["sourceClass"]
          }
        },
        "required": ["provenance"]
      },
      "then": {
        "properties": {
          "provenance": {
            "properties": {
              "derivedFrom": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": { "split": { "const": "calibration-public" } },
        "required": ["split"]
      },
      "then": {
        "properties": {
          "provenance": {
            "properties": {
              "reviewStatus": {
                "not": { "const": "holdout_approved" }
              },
              "notes": {
                "pattern": "[Cc]ontamination"
              }
            }
          }
        }
      }
    }
  ],
  "$defs": {
    "language": {
      "type": "string",
      "enum": ["en", "es", "fr", "ar", "de", "ja", "hi"]
    },
    "reference": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "quality": { "type": "string" },
        "text": { "type": "string" },
        "html": { "type": "string" },
        "notes": { "type": "string" }
      }
    },
    "checks": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "sourceShouldChange": { "type": "boolean" },
        "expectedPatterns": {
          "type": "array",
          "items": { "type": "string" }
        },
        "forbiddenPatterns": {
          "type": "array",
          "items": { "type": "string" }
        },
        "preservedSubstrings": {
          "type": "array",
          "items": { "type": "string" }
        },
        "preservedSubstringCounts": {
          "type": "array",
          "items": { "$ref": "#/$defs/preservedSubstringCount" }
        },
        "markdownMarkers": {
          "type": "array",
          "items": { "type": "string" }
        },
        "markdownStructure": { "$ref": "#/$defs/markdownStructure" },
        "exactOutputOptions": {
          "type": "array",
          "items": { "type": "string" }
        },
        "checkBalancedQuotes": { "type": "boolean" },
        "requiredSelectors": {
          "type": "array",
          "items": { "type": "string" }
        },
        "domSelectorCounts": {
          "type": "array",
          "items": { "$ref": "#/$defs/domSelectorCount" }
        },
        "domVisibleText": {
          "type": "array",
          "items": { "$ref": "#/$defs/domVisibleText" }
        },
        "preservedAttributes": {
          "type": "array",
          "items": { "$ref": "#/$defs/preservedAttribute" }
        },
        "translatedAttributes": {
          "type": "array",
          "items": { "$ref": "#/$defs/translatedAttribute" }
        },
        "domHiddenText": {
          "type": "array",
          "items": { "$ref": "#/$defs/domTextIsland" }
        },
        "domSkippedText": {
          "type": "array",
          "items": { "$ref": "#/$defs/domTextIsland" }
        },
        "domRootDir": { "$ref": "#/$defs/domRootDir" },
        "domExecutableSafety": { "type": "boolean" }
      }
    },
    "preservedSubstringCount": {
      "type": "object",
      "additionalProperties": false,
      "required": ["value"],
      "properties": {
        "value": { "type": "string", "minLength": 1 },
        "count": { "type": "integer", "minimum": 1 },
        "caseSensitive": { "type": "boolean", "default": true }
      }
    },
    "markdownStructure": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "headings": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["level", "count"],
            "properties": {
              "level": { "type": "integer", "minimum": 1, "maximum": 6 },
              "count": { "type": "integer", "minimum": 0 }
            }
          }
        },
        "unorderedListItems": { "type": "integer", "minimum": 0 },
        "orderedListItems": { "type": "integer", "minimum": 0 },
        "minListDepth": { "type": "integer", "minimum": 0 },
        "fencedCodeBlocks": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "count": { "type": "integer", "minimum": 0 },
            "languages": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        },
        "inlineCode": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "count": { "type": "integer", "minimum": 0 },
            "texts": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        },
        "links": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "count": { "type": "integer", "minimum": 0 },
            "labels": {
              "type": "array",
              "items": { "type": "string" }
            },
            "hrefs": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        },
        "images": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "count": { "type": "integer", "minimum": 0 },
            "altTexts": {
              "type": "array",
              "items": { "type": "string" }
            },
            "srcs": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        },
        "tables": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "rows": { "type": "integer", "minimum": 0 },
            "cells": { "type": "integer", "minimum": 0 }
          }
        },
        "blockquotes": { "type": "integer", "minimum": 0 },
        "frontmatter": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "keys": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        }
      }
    },
    "preservedAttribute": {
      "type": "object",
      "additionalProperties": false,
      "required": ["selector", "attribute", "value"],
      "properties": {
        "selector": { "type": "string" },
        "attribute": { "type": "string" },
        "value": { "type": "string" }
      }
    },
    "domSelectorCount": {
      "type": "object",
      "additionalProperties": false,
      "required": ["selector", "count"],
      "properties": {
        "selector": { "type": "string" },
        "count": { "type": "integer", "minimum": 0 }
      }
    },
    "domVisibleText": {
      "type": "object",
      "additionalProperties": false,
      "required": ["selector"],
      "anyOf": [
        { "required": ["text"] },
        { "required": ["pattern"] }
      ],
      "properties": {
        "selector": { "type": "string" },
        "text": { "type": "string" },
        "pattern": { "type": "string" }
      }
    },
    "translatedAttribute": {
      "type": "object",
      "additionalProperties": false,
      "required": ["selector", "attribute"],
      "properties": {
        "selector": { "type": "string" },
        "attribute": { "type": "string" },
        "expectedText": { "type": "string" },
        "expectedPattern": { "type": "string" },
        "forbiddenPattern": { "type": "string" },
        "shouldChange": { "type": "boolean", "default": true }
      }
    },
    "domTextIsland": {
      "type": "object",
      "additionalProperties": false,
      "required": ["selector"],
      "properties": {
        "selector": { "type": "string" },
        "text": { "type": "string" }
      }
    },
    "domRootDir": {
      "type": "object",
      "additionalProperties": false,
      "required": ["dir"],
      "properties": {
        "selector": { "type": "string" },
        "dir": { "type": "string", "enum": ["ltr", "rtl"] }
      }
    },
    "runner": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "dom": { "$ref": "#/$defs/domRunner" }
      }
    },
    "domRunner": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "richText": {
          "type": "object",
          "additionalProperties": false,
          "required": ["selector", "sourceAttribute"],
          "properties": {
            "selector": { "type": "string" },
            "sourceAttribute": { "type": "string" }
          }
        },
        "structuredText": {
          "type": "object",
          "additionalProperties": false,
          "required": ["selector"],
          "properties": {
            "selector": { "type": "string" }
          }
        },
        "linkedBy": {
          "type": "object",
          "additionalProperties": false,
          "required": ["selector", "keyAttribute"],
          "properties": {
            "selector": { "type": "string" },
            "keyAttribute": { "type": "string" }
          }
        },
        "translateAttributes": {
          "type": "array",
          "items": { "type": "string" }
        },
        "preserveMatchers": {
          "type": "array",
          "items": { "type": "string" }
        },
        "skipTags": {
          "type": "array",
          "items": { "type": "string" }
        },
        "skipTextPatterns": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sourceClass",
        "authorId",
        "createdAt",
        "sourceOrigin",
        "derivedFrom",
        "publicExposure",
        "reviewStatus",
        "referenceTranslatorId",
        "referenceReviewerId",
        "referenceReviewDate",
        "technicalReviewerId",
        "technicalReviewDate",
        "notes"
      ],
      "properties": {
        "sourceClass": {
          "type": "string",
          "enum": [
            "first_party_authored",
            "product_derived_rewrite",
            "synthetic_template",
            "public_benchmark",
            "public_web",
            "unknown"
          ]
        },
        "authorId": { "type": "string", "minLength": 1 },
        "createdAt": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        },
        "sourceOrigin": {
          "type": "string",
          "minLength": 1,
          "not": { "enum": ["private", "internal", "unknown"] }
        },
        "derivedFrom": {
          "type": ["string", "null"],
          "minLength": 1
        },
        "publicExposure": {
          "type": "string",
          "enum": ["private", "public", "mixed", "unknown"]
        },
        "reviewStatus": {
          "type": "string",
          "enum": [
            "draft",
            "reference_reviewed",
            "technical_reviewed",
            "holdout_approved",
            "deprecated"
          ]
        },
        "referenceTranslatorId": { "type": "string", "minLength": 1 },
        "referenceReviewerId": { "type": "string", "minLength": 1 },
        "referenceReviewDate": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        },
        "technicalReviewerId": { "type": "string", "minLength": 1 },
        "technicalReviewDate": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        },
        "notes": { "type": "string", "minLength": 1 }
      }
    }
  }
}
