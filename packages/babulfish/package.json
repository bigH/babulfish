{
  "name": "babulfish",
  "version": "0.1.0",
  "description": "Convenience meta-package re-exporting @babulfish/react.",
  "license": "MIT",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bigH/babulfish.git",
    "directory": "packages/babulfish"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./css": "./src/babulfish.css"
  },
  "files": [
    "dist",
    "src/babulfish.css"
  ],
  "scripts": {
    "build": "tsup",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@babulfish/react": "workspace:^",
    "@babulfish/styles": "workspace:^"
  },
  "peerDependencies": {
    "@huggingface/transformers": "^4.0.0",
    "react": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "@huggingface/transformers": {
      "optional": true
    }
  },
  "devDependencies": {
    "tsup": "^8.4.0",
    "typescript": "^5.8.3"
  }
}
