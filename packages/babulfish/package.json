{
  "name": "babulfish",
  "version": "0.1.0",
  "description": "Client-side browser translation with React, DOM, and engine entrypoints powered by TranslateGemma.",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bigH/babulfish.git",
    "directory": "packages/babulfish"
  },
  "homepage": "https://github.com/bigH/babulfish/tree/main/packages/babulfish#readme",
  "bugs": {
    "url": "https://github.com/bigH/babulfish/issues"
  },
  "keywords": [
    "translation",
    "i18n",
    "webgpu",
    "wasm",
    "react",
    "dom"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./engine": {
      "import": "./dist/engine.js",
      "types": "./dist/engine.d.ts"
    },
    "./dom": {
      "import": "./dist/dom.js",
      "types": "./dist/dom.d.ts"
    },
    "./react": {
      "import": "./dist/react.js",
      "types": "./dist/react.d.ts"
    },
    "./css": "./dist/css/babulfish.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup && mkdir -p dist/css && cp src/css/babulfish.css dist/css/babulfish.css",
    "docs:check": "tsc -p tsconfig.docs.json --pretty false && node ./scripts/consumer-smoke.mjs",
    "consumer:smoke": "node ./scripts/consumer-smoke.mjs",
    "test": "vitest run",
    "lint": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "@huggingface/transformers": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "@huggingface/transformers": {
      "optional": true
    }
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "jsdom": "^26.1.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tsup": "^8.4.0",
    "typescript": "^5.8.3",
    "vitest": "^3.1.1"
  }
}
