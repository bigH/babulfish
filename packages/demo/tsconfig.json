{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "noEmit": true,
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "baseUrl": ".",
    "paths": {
      "babulfish": [
        "../babulfish/src/index.ts"
      ],
      "babulfish/react": [
        "../babulfish/src/react/index.ts"
      ],
      "babulfish/dom": [
        "../babulfish/src/dom/index.ts"
      ],
      "babulfish/engine": [
        "../babulfish/src/engine/index.ts"
      ]
    },
    "jsx": "preserve"
  },
  "include": [
    "app/**/*.ts",
    "app/**/*.tsx",
    "next-env.d.ts",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
